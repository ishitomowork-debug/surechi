# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/realmatching

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=7d

# Location radius (in meters)
LOCATION_RADIUS=1000

# Socket.IO
SOCKET_IO_CORS=http://localhost:3000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Email (SMTP) - optional, logs to console if not set
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@realmatching.app
