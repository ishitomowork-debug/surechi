# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=production

# ===========================
# MongoDB (MongoDB Atlas推奨)
# 例: mongodb+srv://<user>:<pass>@cluster.mongodb.net/surechi
# ===========================
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/surechi

# ===========================
# JWT
# openssl rand -base64 64 で生成
# ===========================
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_SECRET
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_USE_ANOTHER_STRONG_SECRET
REFRESH_TOKEN_EXPIRE=30d

# ===========================
# CORS / Frontend
# RailwayのデプロイURLを設定
# ===========================
SOCKET_IO_CORS=*
FRONTEND_URL=https://your-app.up.railway.app

# ===========================
# Location
# ===========================
LOCATION_RADIUS=1000

# ===========================
# Email (SendGrid推奨 / 未設定時はコンソール出力)
# ===========================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx
# SMTP_FROM=noreply@surechi.app

# ===========================
# 開発者専用機能（/api/dev/*）
# 自分のユーザーIDをMongoDBから確認して設定
# ===========================
# DEV_USER_ID=your_mongodb_user_id_here

# ===========================
# APNs (iOS プッシュ通知)
# Apple Developer ConsoleからP8キーをダウンロード
# ===========================
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_KEY_CONTENT=-----BEGIN PRIVATE KEY-----\nMIGHAgEA...\n-----END PRIVATE KEY-----
# APNS_BUNDLE_ID=com.yourteam.surechi
# APNS_PRODUCTION=true
